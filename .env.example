# Local default:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Render web service:
# NEXT_PUBLIC_SITE_URL=https://rag-lens-mx20.onrender.com
# GitHub Pages public entry allowed to call /api/warmup on Render:
# NEXT_PUBLIC_LANDING_ORIGIN=https://lagarcess.github.io
# Optional comma-separated warmup allowlist for additional public origins:
# NEXT_PUBLIC_WARMUP_ALLOWED_ORIGINS=https://lagarcess.github.io

# Browser-safe Supabase values. Use publishable/anon key only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase values. Never expose these with NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=rag-uploads

# Local Supabase CLI only. Used for `supabase link`; not required by Next.js,
# Supabase monthly cleanup, or Render runtime services.
SUPABASE_PROJECT_REF=

# Local Render deployment preflight only. Set the ID after the dedicated Render
# workspace exists; until then the preflight intentionally blocks deployment
# from unrelated workspaces.
RENDER_EXPECTED_WORKSPACE_NAME=rag-lens
RENDER_EXPECTED_WORKSPACE_ID=tea-d8vvqob7uimc738uflsg

# Perplexity server-only values. Used for embeddings.
PERPLEXITY_API_KEY=
PERPLEXITY_EMBEDDING_MODEL=pplx-embed-v1-0.6b
PERPLEXITY_CONTEXT_EMBEDDING_MODEL=pplx-embed-context-v1-0.6b

# Chat generation. OpenRouter is the preferred V1 answer provider.
CHAT_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=deepseek/deepseek-v4-flash
# Local default:
OPENROUTER_HTTP_REFERER=http://localhost:3000
# Render web service:
# OPENROUTER_HTTP_REFERER=https://rag-lens-mx20.onrender.com
OPENROUTER_APP_TITLE="RAG Lens"
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_MAX_COMPLETION_TOKENS=900
OPENROUTER_REASONING_EFFORT=none
OPENROUTER_REASONING_EXCLUDE=true

# Retrieval backend. Use `local` for zero-dependency local example traces.
# Hosted V1/Render should use `supabase` because example chunks are seeded.
RAG_RETRIEVAL_BACKEND=local

# Public demo cleanup.
RAG_SESSION_SOFT_TTL_HOURS=2
RAG_SESSION_HARD_TTL_HOURS=24
CLEANUP_BATCH_SIZE=100
# Supabase monthly cleanup Edge Function and Vault secret. Generate a random
# value; do not expose it to the browser or Render.
RAG_LENS_CLEANUP_TOKEN=

# In-memory public API throttles. These are per Render instance and intended as
# a V1 abuse brake, not a distributed rate-limit system.
RAG_RATE_LIMIT_WINDOW_MS=60000
RAG_RATE_LIMIT_QUERY_MAX=20
RAG_RATE_LIMIT_UPLOAD_MAX=6
RAG_RATE_LIMIT_SESSION_MAX=10
